# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/food-delivery-app

# JWT Secret Keys
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1h

# Logging
LOG_LEVEL=debug

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
